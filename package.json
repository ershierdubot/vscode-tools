{
  "name": "vscode-tools",
  "displayName": "VSCode Tools",
  "description": "A collection of useful development tools including Parquet Viewer, JSON Formatter, and more",
  "version": "0.3.0",
  "publisher": "ershierdu",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Data Science",
    "Debuggers"
  ],
  "keywords": [
    "parquet",
    "json",
    "base64",
    "timestamp",
    "data viewer",
    "development tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ershierdubot/vscode-tools"
  },
  "bugs": {
    "url": "https://github.com/ershierdubot/vscode-tools/issues"
  },
  "homepage": "https://github.com/ershierdubot/vscode-tools#readme",
  "license": "MIT",
  "activationEvents": [
    "onView:vscodeToolsSidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscodeTools",
          "title": "VSCode Tools",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "vscodeTools": [
        {
          "id": "vscodeToolsSidebar",
          "name": "Tools",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "vscodeTools.openParquetViewer",
        "title": "Open Parquet Viewer",
        "icon": "$(file-binary)",
        "category": "VSCode Tools"
      },
      {
        "command": "vscodeTools.openJsonFormatter",
        "title": "Open JSON Formatter",
        "icon": "$(bracket)",
        "category": "VSCode Tools"
      },
      {
        "command": "vscodeTools.refreshTools",
        "title": "Refresh Tools",
        "icon": "$(refresh)",
        "category": "VSCode Tools"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vscodeTools.refreshTools",
          "when": "view == vscodeToolsSidebar",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "echo \"Error: no test specified\" && exit 0",
    "package": "vsce package",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "parquetjs": "^0.11.0"
  }
}
